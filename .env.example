# ╔══════════════════════════════════════════════════════════════╗
# ║           Discord Radio Bot — Орчны тохиргоо (.env)         ║
# ╚══════════════════════════════════════════════════════════════╝
#
# 📌 ЗААВАР:
#   1. Энэ файлыг ".env.example" → ".env" гэж хуулна уу:
#      cp .env.example .env
#   2. Доорх утгуудыг өөрийн мэдээллээр сольно уу.
#   3. .env файлыг хэзээ ч git-д оруулж болохгүй!
#      (.gitignore-д .env нэмэхээ мартуузай)
#
# ─────────────────────────────────────────────────────────────────

# 🤖 DISCORD BOT TOKEN
#   Discord Developer Portal → Таны апп → Bot → Token
#   https://discord.com/developers/applications
TOKEN=your_bot_token_here

# 🆔 APPLICATION (CLIENT) ID
#   Discord Developer Portal → Таны апп → General Information → Application ID
#   deploy-commands.js скриптэд хэрэглэнэ
CLIENT_ID=your_application_id_here

# 🏠 GUILD (SERVER) ID
#   Discord-ийн Settings → Advanced → Developer Mode асааж,
#   серверийнхээ нэр дээр баруун товчлуур → "Copy Server ID"
GUILD_ID=your_guild_id_here

# 🔊 VOICE CHANNEL ID
#   Voice channel дээр баруун товчлуур → "Copy Channel ID"
CHANNEL_ID=your_voice_channel_id_here

# 📻 РАДИО СТРИМ URL
#   Жишээнүүд:
#     • Mongolian radio:  https://example-radio.mn/stream
#     • MP3 stream:       http://stream.example.com:8000/radio.mp3
#     • Icecast/Shoutcast stream URL
RADIO_URL=https://your-radio-stream-url.com/stream
